# Enable Rewrite Engine for React SPA Routing inside build folder
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Pass the Authorization header to PHP (needed for JWT in cPanel/Hostinger)
  RewriteCond %{HTTP:Authorization} .
  RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
  
  # Exclude /api directory from rewrites so backend requests work
  RewriteCond %{REQUEST_URI} ^/api/ [NC]
  RewriteRule ^ - [L]

  # If the requested filename exists as a file or directory, serve it directly
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
  
  # Rewrite all other routes (like /admin, /services) to index.html
  RewriteRule ^(.*)$ index.html [L]
</IfModule>

# Adjust PHP upload configurations if supported
<IfModule mod_php7.c>
  php_value upload_max_filesize 64M
  php_value post_max_size 64M
  php_value memory_limit 128M
</IfModule>
<IfModule mod_php.c>
  php_value upload_max_filesize 64M
  php_value post_max_size 64M
  php_value memory_limit 128M
</IfModule>

# Enable Gzip Compression for faster page loads
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>
